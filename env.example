# ─────────────────────────────────────────────
#  VULNRA — Environment Variables
#  Copy this file to .env and fill in your values
#  NEVER commit .env to version control
# ─────────────────────────────────────────────

# ── Required ──────────────────────────────────

# Redis connection string
# Local Docker:  redis://redis:6379
# Upstash TLS:   rediss://default:PASSWORD@HOST.upstash.io:6379
REDIS_URL=redis://redis:6379

# Random secret key for session signing
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret


# ── Model API Keys (add the ones you need) ────

# OpenAI
OPENAI_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# Hugging Face
HUGGINGFACE_API_KEY=

# Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=


# ── Optional ──────────────────────────────────

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Max concurrent scans (default: 3)
MAX_CONCURRENT_SCANS=3

# Scan timeout in seconds (default: 300)
SCAN_TIMEOUT=300
